set(LFG_VERSION      @LFG_INSTALL_VERSION@)
set(LFG_BUILD_COMMIT @LFG_BUILD_COMMIT@)
set(LFG_BUILD_NUMBER @LFG_BUILD_NUMBER@)
set(LFG_SHARED_LIB   @BUILD_SHARED_LIBS@)

@PACKAGE_INIT@

set_and_check(LFG_INCLUDE_DIR "@PACKAGE_LFG_INCLUDE_INSTALL_DIR@")
set_and_check(LFG_LIB_DIR     "@PACKAGE_LFG_LIB_INSTALL_DIR@")
set_and_check(LFG_BIN_DIR     "@PACKAGE_LFG_BIN_INSTALL_DIR@")

find_package(ggml REQUIRED HINTS ${LFG_LIB_DIR}/cmake)

find_library(lfg_LIBRARY liquid
    REQUIRED
    HINTS ${LFG_LIB_DIR}
    NO_CMAKE_FIND_ROOT_PATH
)

add_library(liquid UNKNOWN IMPORTED)
set_target_properties(liquid
    PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${LFG_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
        IMPORTED_LOCATION "${lfg_LIBRARY}"
        INTERFACE_COMPILE_FEATURES c_std_90
        POSITION_INDEPENDENT_CODE ON)

check_required_components(Liquid)
