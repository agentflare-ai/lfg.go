prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=@CMAKE_INSTALL_PREFIX@
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@

Name: liquid
Description: Port of Facebook's Liquid model in C/C++
Version: @LFM_INSTALL_VERSION@
Libs: -L${libdir} -lggml -lggml-base -lliquid
Cflags: -I${includedir}
